model Chat {
    id          Int      @id @default(autoincrement())
    user_id     Int
    receiver_id Int
    message     String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@index([createdAt])
    @@map("chats")
}
